# ─── DATABASE ─────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/bos_dev"

# ─── REDIS ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── AUTH (JWT) ───────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_64_CHAR_RANDOM_HEX"
JWT_REFRESH_SECRET="REPLACE_WITH_ANOTHER_64_CHAR_HEX"

# ─── NEXT.JS ──────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BOS"

# ─── OPENAI ───────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── WHATSAPP (Meta Business API) ─────────────────────────────
# From: developers.facebook.com → Your App → WhatsApp → API Setup
WA_TOKEN="EAABs..."                      # Permanent System User Access Token
WA_PHONE_ID="1234567890"                 # Phone Number ID (not the number itself)
WA_BUSINESS_ACCOUNT_ID="0987654321"      # WhatsApp Business Account ID
WA_PHONE_NUMBER="919876543210"           # Your WhatsApp Business number (with country code, no +)
WA_VERIFY_TOKEN="my-webhook-verify-token-change-this"   # You choose this for webhook verification

# ─── EMAIL (SendGrid) ─────────────────────────────────────────
SENDGRID_API_KEY="SG.xxxxxx"
EMAIL_FROM_ADDRESS="noreply@yourdomain.com"
EMAIL_FROM_NAME="BOS Platform"

# ─── BILLING (Razorpay — Indian payments) ─────────────────────
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."
RAZORPAY_WEBHOOK_SECRET="..."
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_..."

# ─── BILLING (Stripe — International) ─────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── FILE UPLOADS (Optional: Cloudflare R2 / AWS S3) ──────────
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_ENDPOINT=""
NEXT_PUBLIC_CDN_URL=""
