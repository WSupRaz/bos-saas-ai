{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib":    ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@bos/database": ["../../packages/database/index.ts"],
      "@bos/shared":   ["../../packages/shared/index.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
